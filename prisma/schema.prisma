/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  price            Decimal            @default(0) @db.Decimal
  image_url        String?
  category_id      String?            @db.Uuid
  rarity_id        String?            @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  stock            Int                @default(0)
  featured         Boolean            @default(false)
  rating           Decimal?           @default(0) @db.Decimal
  pricing_options  Json               @default("[]")
  categories       categories?        @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rarities         rarities?          @relation(fields: [rarity_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seller_inventory seller_inventory[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                                                 String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                         DateTime                  @default(now()) @db.Timestamptz(6)
  username                                           String?
  avatar_url                                         String?
  name                                               String?
  nick                                               String?
  phone                                              String?
  game_id                                            String?
  is_admin                                           Boolean                   @default(true)
  is_seller                                          Boolean                   @default(false)
  updated_at                                         DateTime                  @default(now()) @db.Timestamptz(6)
  email                                              String?
  status                                             String                    @default("active")
  is_banned                                          Boolean                   @default(false)
  total_spent                                        Decimal                   @default(0) @db.Decimal
  total_orders                                       Int                       @default(0)
  orders                                             orders[]
  seller_inventory                                   seller_inventory[]
  seller_payouts_seller_payouts_created_byToprofiles seller_payouts[]          @relation("seller_payouts_created_byToprofiles")
  seller_payouts_seller_payouts_seller_idToprofiles  seller_payouts[]          @relation("seller_payouts_seller_idToprofiles")
  support_ticket_messages                            support_ticket_messages[]
  support_tickets                                    support_tickets[]
  team_members                                       team_members[]
}

